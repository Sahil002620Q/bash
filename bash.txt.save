bash --version
ls
cd 
pwd
echo
cat
cp
mv
rm
touch 
dir

#args for ls
ls -l  --long list
ls -a  --shows hidden dir 
ls -lh --file in human readable size format i.e in kb,mb,gb
ls -t
ls  arg -r
ls -R  --shows subdirectories recursively
ls -S
ls -1  --only yone dir at one line
ls -d
ls -F --shows with dirname + '/' at end of dir name

#detailed
ls -l
file permission | number of links | owner name | owner group | file size | last modification time in month date time format | file/dir name

ls -a
hidden files in .file and .folder format

ls -lh
convert file size in kb mb or gb in file size row rest full format is same as ls -l

ls -t
sort dir and files by modification time

ls -r 
reverse the output can be used with other arg

ls -R
show dir with sub dir recursively

ls -S
sort by size

ls -1
one file/dir per line

ls -d */
only dir with no content

#cd args
cd .. --go outside current dir
cd ~  --switch to home dir
cd -  --switch to previous dir
cd /  --switch to root dir
cd dir_namr  --go to that dir

#use && to combine two commands
cd home && ls

#pwd
pwd -P  --print physical working dir
pwd -L

#echo args
echo -e  --enable backslash escape
echo -E  --disable backslash escape
echo -n  --no tailing newline , same as end='' in python

#cat args
cat -v --show hidden \n like non printing characters
cat -n --show number in front of each line 
cat -b --same as -n but ignore empty lines
cat -s --remove extra empty lines
cat file1.txt file2.txt > combined.txt --merges files to make one single file
cat file.txt | grep "shell"  --send file to another command

#cp
cp orignal.txt copy.txt
cp -r --recursively copy all file and folder
cp -i --ask for replacing file
cp -u --copy ony if source is new than destination
cp -v --show file being copy (verbose mode)
co *.txt destination/ --copy all file to destination

#mv
mv source destination
mv oldname.txt newname.txt
mv file.txt home/sahil/folder
mv -i --ask while replacing file
mv -u --move if source is new than destination
mv -v --show while file is moving
mv *.txt destination/ move all file to destination

#rm
rm file.txt -remove file
rm -r --recursively remove all file/folder  in that folder
rm -f --force remove file or folder 
rm -i --ask before deleting each file
rm -v --show while removing file/folder

#touch
touch -a
touch -m --change modification time
touch -t
touch -c

